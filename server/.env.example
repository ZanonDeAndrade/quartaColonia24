PORT=3005
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://*.onrender.com

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

JWT_ACCESS_SECRET=replace-with-at-least-32-characters-for-access-token
JWT_REFRESH_SECRET=replace-with-at-least-32-characters-for-refresh-token
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
UPLOAD_MAX_BYTES=5242880

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash
